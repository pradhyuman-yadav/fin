# Copy to .env and fill in. NEVER commit .env.

# TimescaleDB (matches docker-compose.yml defaults)
POSTGRES_USER=fin
POSTGRES_PASSWORD=fin_dev_pw
POSTGRES_DB=fin
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://fin:fin_dev_pw@localhost:5432/fin

# Alpaca market data (https://app.alpaca.markets/ -> API keys)
# Read-only data ingestion. Free accounts must use feed=iex.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_TRADE_URL=https://paper-api.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets
ALPACA_FEED=iex
ALPACA_CRYPTO_LOC=us

# API keys — add what your tools need.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
